class Juego {
    - Submarino submarino
    - Arrecife arrecife
    - BarreraCoral barreras[4]
    - Ronda rondas[4]
    - Puntaje puntaje
    - EstadoJuego estadoJuego
    - Temporizador temporizador
    + Iniciar()
    + Actualizar()
    + Dibujar()
    + CambiarRonda()
    + VerificarVictoria() : EstadoJuego
    + VerificarDerrota() : EstadoJuego
}

class Submarino {
    - BarraOxigeno barraOxigeno
    - Posicion posicion
    - Velocidad velocidad
    - CadenciaDisparo cadenciaDisparo
    + MoverIzquierda()
    + MoverDerecha()
    + Disparar() : Torpedo
    + RecibirDano(Enemigo)
    + ConsumirOxigeno(Tiempo)
    + RegenerarOxigeno(Recolectable)
    + AplicarPowerUp(PowerUp)
}

class Arrecife {
    - Vida vida
    - Posicion posicion
    + RecibirImpacto(ProyectilEnemigo)
    + EstaDestruido() : EstadoJuego
}

class BarreraCoral {
    - Vida vida
    - Posicion posicion
    - EstadoBarrera estadoBarrera
    + RecibirImpacto(Proyectil)
    + BloquearProyectil(Proyectil)
    + ActualizarEstado() : EstadoBarrera
    + EstaDestruida() : EstadoJuego
}

class Enemigo {
    - Vida vida
    - DanoOxigeno danoOxigeno
    - Velocidad velocidad
    - CadenciaDisparo cadenciaDisparo
    - Posicion posicion
    - ProbabilidadPowerUp probabilidadPowerUp
    + MoverFormacion()
    + DescenderFila()
    + Disparar() : ProyectilEnemigo
    + RecibirDano(Torpedo)
    + SoltarPowerUp() : PowerUp
    + EstaDestruido() : EstadoJuego
}

class Jefe {
    + ActivarFase()
    + DispararRafaga() : ProyectilJefe
    + LanzarPowerUp() : PowerUp
}

class PulpoLeviatan {
    - FaseJefe faseJefe
    + MoverErratico()
}

class Proyectil {
    - DanoVida danoVida
    - Posicion posicion
    - Velocidad velocidad
    + Mover()
    + Impactar()
}

class Torpedo {
    + ImpactarEnemigo(Enemigo)
    + ImpactarBarrera(BarreraCoral)
}

class ProyectilEnemigo {
    - DanoOxigeno danoOxigeno
    + ImpactarSubmarino(Submarino)
    + ImpactarArrecife(Arrecife)
    + ImpactarBarrera(BarreraCoral)
}

class Recolectable {
    - Posicion posicion
    + Caer()
    + Recolectar(Submarino)
}

class PowerUp {
    - Duracion duracion
    + Activar(Submarino)
    + Expirar()
}

class SuministroOxigeno {
    - RecuperacionOxigeno recuperacionOxigeno
}

class BurbujaOxigeno {
    - RecuperacionOxigeno recuperacionOxigeno
    + Desaparecer()
}

class Ronda {
    - Velocidad velocidad
}

class Temporizador {
    - Tiempo tiempo
}

note right of Submarino
Movimiento horizontal.
Dispara torpedos hacia arriba.
Cadencia: 1 torpedo cada 0.5 segundos.
No tiene vidas: depende de oxígeno.
end note

note right of BarraOxigeno
Oxígeno inicial: 100 puntos.
Pérdida pasiva: -2 cada 5 segundos.
Si llega a 0, el jugador pierde.
end note

note right of Arrecife
Vida inicial: 150 puntos.
No se regenera entre rondas.
Si llega a 0, el jugador pierde.
end note

note right of BarreraCoral
Cantidad: 4 barreras.
Vida inicial: 40 puntos.
Cada impacto causa -5 puntos.
No se regeneran entre rondas.
end note

note right of EstadoBarrera
40-30 HP: Coral intacto.
29-15 HP: Coral agrietado.
14-1 HP: Coral fracturado.
0 HP: Destruido.
end note

note right of Medusa
Vida: 10 HP.
Daño jugador: -10 oxígeno.
Velocidad: rápida.
Disparo: cada 3 segundos.
end note

note right of Calamar
Vida: 20 HP.
Daño jugador: -15 oxígeno.
Velocidad: media.
Disparo: cada 2.5 segundos.
end note

note right of Cangrejo
Vida: 30 HP.
Daño jugador: -20 oxígeno.
Velocidad: lenta.
Disparo: cada 2 segundos.
end note

note right of PulpoLeviatan
Vida: 200 HP.
Daño: -25 oxígeno.
Fase 1: disparos rectos.
Fase 2: ráfagas de 3 proyectiles.
Aparece en ronda 4.
end note

note right of DobleDisparo
Dispara 2 torpedos simultáneamente.
Duración: 10 segundos.
end note

note right of VelocidadAumentada
Aumenta movimiento 50%.
Duración: 5 segundos.
end note

note right of SuministroOxigeno
Restaura 30 puntos de oxígeno.
Efecto instantáneo.
end note

note right of BurbujaOxigeno
Aparece cada 15 segundos.
Restaura 15 puntos de oxígeno.
Cae lentamente y desaparece al fondo.
end note

note right of InvasionInicial
Ronda 1.
15 enemigos.
Velocidad normal.
Oxígeno se regenera al terminar.
end note

note right of OleadaReforzada
Ronda 2.
18 enemigos.
Velocidad 25% mayor.
Oxígeno se regenera al terminar.
end note

note right of AsaltoMasivo
Ronda 3.
21 enemigos.
Velocidad 50% mayor.
Oxígeno se regenera al terminar.
end note

note right of RondaJefe
Ronda 4.
Jefe final: PulpoLeviatan.
Condición de victoria: derrotar al jefe.
Oxígeno se regenera al comenzar.
end note
@enduml